#!/usr/bin/env node
import { execute } from '@oclif/core'
import { readFileSync } from 'node:fs'
import { fileURLToPath } from 'node:url'
import { dirname } from 'node:path'

const __filename = fileURLToPath(import.meta.url)
const __dirname = dirname(__filename)

const version = process.env.VERSION || JSON.parse(readFileSync(`${__dirname}/../package.json`, 'utf8')).version

// Auto-add 'default' subcommand if no subcommand is provided
const rawArgs = process.argv.slice(2)
const firstArg = rawArgs[0]
const args = firstArg && !firstArg.startsWith('-') ? rawArgs : ['default', ...rawArgs]

const isDev = process.env.GIT_REWORD_DEV === '1'
const rootDir = `${__dirname}/..`

await execute({
  dir: __dirname,
  development: isDev,
  version,
  args,
  loadOptions: isDev
    ? {
        root: rootDir,
        pjson: {
          name: 'git-reword',
          version,
          oclif: {
            commands: `${rootDir}/src/commands`,
          },
        },
      }
    : undefined,
})
