{
  "name": "git-reword",
  "version": "0.0.0",
  "description": "AI-powered Git commit message rewriter",
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/types/index.d.ts",
      "default": "./lib/esm/index.js"
    }
  },
  "types": "./lib/types/index.d.js",
  "files": [
    "lib"
  ],
  "bin": {
    "git-reword": "./bin/run"
  },
  "oclif": {
    "bin": "git-reword",
    "dirname": "git-reword",
    "commands": "./lib/commands",
    "plugins": []
  },
  "scripts": {
    "dev": "node --loader ts-node/esm ./src/index.ts",
    "clean": "rimraf ./lib",
    "prebuild": "npm run clean",
    "build": "tsc -p ./tsconfig.esm.json",
    "build:cli": "tsc -p ./tsconfig.cli.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check . --fix",
    "format": "biome format . --write",
    "prepare": "husky",
    "release": "np"
  },
  "engines": {
    "node": ">= 22"
  },
  "repository": {
    "url": "imyelo/git-reword",
    "type": "git"
  },
  "author": "yelo <zhihuzeye@gmail.com>",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/imyelo/git-reword/issues"
  },
  "homepage": "https://github.com/imyelo/git-reword#readme",
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/google": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "ai": "^4.0.0",
    "c12": "^2.0.0",
    "oclif": "^4.22.77",
    "simple-git": "^3.27.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@yelo/biome-config": "^0.1.3",
    "@yelo/tsconfig": "^0.6.0",
    "@types/node": "^22.0.0",
    "husky": "^9.1.7",
    "np": "^10.0.0",
    "rimraf": "^6.0.0",
    "tsx": "^4.19.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.4",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  }
}
