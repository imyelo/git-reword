{
  "name": "git-reword",
  "version": "0.0.0",
  "description": "AI-powered Git commit message rewriter",
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/types/index.d.ts",
      "default": "./lib/esm/index.js"
    }
  },
  "types": "./lib/types/index.d.js",
  "files": [
    "lib"
  ],
  "bin": {
    "git-reword": "./bin/run"
  },
  "oclif": {
    "bin": "git-reword",
    "dirname": "git-reword",
    "commands": {
      "strategy": "single",
      "target": "./lib/esm/index.js"
    },
    "plugins": []
  },
  "scripts": {
    "dev": "GIT_REWORD_DEV=1 tsx bin/run",
    "dev:watch": "GIT_REWORD_DEV=1 tsx watch bin/run",
    "clean": "rimraf ./lib",
    "prebuild": "npm run clean",
    "build": "npm run clean && npm run build:cli && npm run build:esm && npm run build:types",
    "build:cli": "tsc -p ./tsconfig.cli.json && node ./bin/copy-assets",
    "build:esm": "tsc -p ./tsconfig.esm.json",
    "build:types": "tsc -p ./tsconfig.json --declaration --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check . --fix",
    "format": "biome format . --write",
    "prepare": "husky",
    "release": "np"
  },
  "engines": {
    "node": ">= 22"
  },
  "repository": {
    "url": "imyelo/git-reword",
    "type": "git"
  },
  "author": "yelo <zhihuzeye@gmail.com>",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/imyelo/git-reword/issues"
  },
  "homepage": "https://github.com/imyelo/git-reword#readme",
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.41",
    "@ai-sdk/google": "3.0.24",
    "@ai-sdk/openai": "3.0.26",
    "@byteland/ink-scroll-bar": "^1.0.0",
    "ai": "6.0.79",
    "c12": "4.0.0-beta.2",
    "ink": "^6.7.0",
    "ink-scroll-view": "^0.3.6",
    "oclif": "4.22.77",
    "react": "^19.2.4",
    "simple-git": "3.27.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@types/node": "25.2.3",
    "@yelo/biome-config": "0.1.3",
    "@yelo/tsconfig": "0.6.0",
    "husky": "9.1.7",
    "np": "10.3.0",
    "rimraf": "6.1.2",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  }
}
